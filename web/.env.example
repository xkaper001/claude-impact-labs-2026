# Server-side only (never shipped to the browser). See web/server/index.js.
ANTHROPIC_API_KEY=sk-ant-...
# Claude model — mirrors config-scoring.json llm.model
CLAUDE_MODEL=claude-opus-4-8
# Voice intake (Talk to family): Sarvam STT + Claude + Sarvam TTS, turn-based.
# Sarvam AI handles Indian-language speech (Hindi/Marathi/English + more).
# Server-side only (never shipped). Get a key at https://dashboard.sarvam.ai
SARVAM_API_KEY=
# Whisper.cpp box for offline STT (kendra box). See DESIGN.md §STT.
WHISPER_BOX_URL=http://192.168.1.10:8080/inference
# CouchDB for replication. Leave blank to run PouchDB-only (offline demo).
COUCHDB_URL=http://admin:admin@localhost:5984
